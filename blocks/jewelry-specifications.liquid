{% assign block_settings = block.settings %}
<div
  class="jewelry-specs jewelry-specs--{{ block.id }} border-style spacing-style"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  <details class="jewelry-specs__details" {% if block_settings.open_by_default %}open{% endif %}>
    <summary class="jewelry-specs__summary h6">
      <span>{{ block_settings.heading | default: 'Specifikationer' }}</span>
      <span class="jewelry-specs__icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </summary>
    <div class="jewelry-specs__content">
      <ul class="jewelry-specs__list">
        {% if block_settings.material != blank or product.metafields.custom.material != blank %}
          <li class="jewelry-specs__item">
            <span class="jewelry-specs__label">Materiale:</span>
            <span class="jewelry-specs__value">
              {% if product.metafields.custom.material != blank %}
                {{ product.metafields.custom.material }}
              {% else %}
                {{ block_settings.material }}
              {% endif %}
            </span>
          </li>
        {% endif %}
        
        {% if block_settings.stone != blank or product.metafields.custom.stone != blank %}
          <li class="jewelry-specs__item">
            <span class="jewelry-specs__label">Sten:</span>
            <span class="jewelry-specs__value">
              {% if product.metafields.custom.stone != blank %}
                {{ product.metafields.custom.stone }}
              {% else %}
                {{ block_settings.stone }}
              {% endif %}
            </span>
          </li>
        {% endif %}

        {% if block_settings.dimensions != blank or product.metafields.custom.dimensions != blank %}
          <li class="jewelry-specs__item">
            <span class="jewelry-specs__label">Mål:</span>
            <span class="jewelry-specs__value">
              {% if product.metafields.custom.dimensions != blank %}
                {{ product.metafields.custom.dimensions }}
              {% else %}
                {{ block_settings.dimensions }}
              {% endif %}
            </span>
          </li>
        {% endif %}

        {% if block_settings.care_summary != blank %}
          <li class="jewelry-specs__item jewelry-specs__item--full">
            <span class="jewelry-specs__label">Pleje:</span>
            <span class="jewelry-specs__value">{{ block_settings.care_summary }}</span>
          </li>
        {% endif %}
      </ul>
      
      {% if block_settings.show_trust_icons %}
        <div class="jewelry-specs__trust-icons">
          {% render 'jewelry-icons', icon: 'silver' %}
          {% render 'jewelry-icons', icon: 'gold' %}
          {% render 'jewelry-icons', icon: 'waterproof' %}
        </div>
      {% endif %}
    </div>
  </details>
</div>

{% stylesheet %}
  .jewelry-specs {
    width: 100%;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .jewelry-specs__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .jewelry-specs__summary::-webkit-details-marker {
    display: none;
  }

  .jewelry-specs__icon {
    transition: transform 0.3s ease;
  }

  .jewelry-specs__details[open] .jewelry-specs__icon {
    transform: rotate(180deg);
  }

  .jewelry-specs__content {
    padding-bottom: 20px;
  }

  .jewelry-specs__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }

  .jewelry-specs__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .jewelry-specs__item--full {
    grid-column: 1 / -1;
  }

  .jewelry-specs__label {
    font-size: 0.75rem;
    color: var(--color-foreground-secondary);
    text-transform: uppercase;
  }

  .jewelry-specs__value {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .jewelry-specs__trust-icons {
    margin-top: 20px;
    display: flex;
    gap: 15px;
    color: var(--color-foreground-secondary);
    opacity: 0.6;
  }

  .jewelry-specs__trust-icons svg {
    width: 20px;
    height: 20px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Jewelry Specifications",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Specifikationer"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "header",
      "content": "Manual Overrides",
      "info": "Leave blank to use Metafields (custom.material, custom.stone, custom.dimensions)"
    },
    {
      "type": "text",
      "id": "material",
      "label": "Material"
    },
    {
      "type": "text",
      "id": "stone",
      "label": "Stone"
    },
    {
      "type": "text",
      "id": "dimensions",
      "label": "Dimensions"
    },
    {
      "type": "textarea",
      "id": "care_summary",
      "label": "Care Summary",
      "default": "Tåler vand, men undgå direkte kontakt med parfume og lotion for længere holdbarhed."
    },
    {
      "type": "checkbox",
      "id": "show_trust_icons",
      "label": "Show Trust Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Jewelry Specifications"
    }
  ]
}
{% endschema %}

{% assign block_settings = block.settings %}
<div
  class="jewelry-specs jewelry-specs--{{ block.id }} border-style spacing-style"
  style="
    --summary-font-family: var(--font-{{ block_settings.type_preset }}--family);
    --summary-font-weight: var(--font-{{ block_settings.type_preset }}--weight);
    --summary-font-size: var(--font-{{ block_settings.type_preset }}--size);
    --summary-font-case: var(--font-{{ block_settings.type_preset }}--case);
    {% render 'spacing-style', settings: block_settings %}
  "
  {{ block.shopify_attributes }}
>
  <details class="jewelry-specs__details" {% if block_settings.open_by_default %}open{% endif %}>
    <summary class="jewelry-specs__summary">
      <span class="jewelry-specs__heading">{{ block_settings.heading | default: 'Specifikationer' }}</span>
      <span class="jewelry-specs__arrow svg-wrapper">
        {{- 'icon-caret.svg' | inline_asset_content -}}
      </span>
    </summary>
    <div class="jewelry-specs__content">
      <div class="jewelry-specs__table">
        {%- liquid
          assign material = product.metafields.custom.material | default: block_settings.material
          assign stone = product.metafields.custom.stone | default: block_settings.stone
          assign dimensions = product.metafields.custom.dimensions | default: block_settings.dimensions
        -%}

        {% if material != blank %}
          <div class="jewelry-specs__row">
            <span class="jewelry-specs__label">Materiale</span>
            <span class="jewelry-specs__value">{{ material }}</span>
          </div>
        {% endif %}
        
        {% if stone != blank %}
          <div class="jewelry-specs__row">
            <span class="jewelry-specs__label">Sten</span>
            <span class="jewelry-specs__value">{{ stone }}</span>
          </div>
        {% endif %}

        {% if dimensions != blank %}
          <div class="jewelry-specs__row">
            <span class="jewelry-specs__label">Mål</span>
            <span class="jewelry-specs__value">{{ dimensions }}</span>
          </div>
        {% endif %}

        {% if block_settings.care_summary != blank %}
          <div class="jewelry-specs__row jewelry-specs__row--full">
            <span class="jewelry-specs__label">Pleje</span>
            <span class="jewelry-specs__value paragraph--small">{{ block_settings.care_summary }}</span>
          </div>
        {% endif %}
      </div>
      
      {% if block_settings.show_trust_icons %}
        <div class="jewelry-specs__trust-icons flex">
          <div class="svg-wrapper" title="925 Sterling Sølv">{% render 'jewelry-icons', icon: 'silver' %}</div>
          <div class="svg-wrapper" title="18K Guld Forgyldning">{% render 'jewelry-icons', icon: 'gold' %}</div>
          <div class="svg-wrapper" title="Ferskvandsperler">{% render 'jewelry-icons', icon: 'waterproof' %}</div>
        </div>
      {% endif %}
    </div>
  </details>
</div>

{% stylesheet %}
  .jewelry-specs {
    width: 100%;
    border-block-start: var(--style-border-width) solid var(--color-border);
  }

  .jewelry-specs__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--padding-md);
    cursor: pointer;
    list-style: none;
    font-family: var(--summary-font-family);
    font-weight: var(--summary-font-weight);
    font-size: var(--summary-font-size);
    text-transform: var(--summary-font-case);
  }

  .jewelry-specs__summary::-webkit-details-marker {
    display: none;
  }

  .jewelry-specs__arrow {
    transition: transform 0.3s ease;
    width: 12px;
    height: 12px;
  }

  .jewelry-specs__details[open] .jewelry-specs__arrow {
    transform: rotate(180deg);
  }

  .jewelry-specs__content {
    padding-block-end: var(--padding-lg);
  }

  .jewelry-specs__table {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .jewelry-specs__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    padding-block-end: 8px;
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.05);
  }

  .jewelry-specs__row--full {
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    border-bottom: none;
  }

  .jewelry-specs__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.5;
    white-space: nowrap;
  }

  .jewelry-specs__value {
    font-size: 0.95rem;
    text-align: right;
  }

  .jewelry-specs__row--full .jewelry-specs__value {
    text-align: left;
    opacity: 0.8;
  }

  .jewelry-specs__trust-icons {
    margin-top: 24px;
    gap: 20px;
    opacity: 0.4;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Jewelry Specifications",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Specifikationer"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.heading_preset",
      "options": [
        { "value": "paragraph", "label": "t:options.paragraph" },
        { "value": "h5", "label": "t:options.h5" },
        { "value": "h6", "label": "t:options.h6" }
      ],
      "default": "h6"
    },
    {
      "type": "header",
      "content": "Manual Overrides",
      "info": "Leave blank to use Metafields (custom.material, custom.stone, custom.dimensions)"
    },
    {
      "type": "text",
      "id": "material",
      "label": "Material"
    },
    {
      "type": "text",
      "id": "stone",
      "label": "Stone"
    },
    {
      "type": "text",
      "id": "dimensions",
      "label": "Dimensions"
    },
    {
      "type": "textarea",
      "id": "care_summary",
      "label": "Care Summary",
      "default": "Tåler vand, men undgå direkte kontakt med parfume og lotion for længere holdbarhed."
    },
    {
      "type": "checkbox",
      "id": "show_trust_icons",
      "label": "Show Trust Icons",
      "default": true
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Jewelry Specifications"
    }
  ]
}
{% endschema %}

{%- capture children -%}
  <div class="jewelry-care-grid">
    <div class="jewelry-care-header">
      <h2 class="h2">{{ section.settings.title | escape }}</h2>
      <p class="paragraph--large">{{ section.settings.subtitle | escape }}</p>
    </div>

    <div class="care-tips-grid">
      {%- for block in section.blocks -%}
        <div class="care-tip-item" {{ block.shopify_attributes }}>
          <h3 class="h6 care-tip-title">
            <span class="care-tip-icon svg-wrapper">
              {{- 'icon-checkmark-burst.svg' | inline_asset_content -}}
            </span>
            {{ block.settings.title | escape }}
          </h3>
          <p class="care-tip-text paragraph--small">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endcapture -%}

{%- render 'section', section: section, children: children -%}

<style>
  .jewelry-care-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 50px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .care-tips-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
    width: 100%;
  }

  .care-tip-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .care-tip-icon {
    color: var(--color-foreground);
    width: 24px;
    height: 24px;
    opacity: 0.8;
  }

  .care-tip-text {
    margin: 0;
    line-height: 1.6;
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .care-tips-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    
    .jewelry-care-header h2 {
      font-size: 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "SIHO Jewellery Care",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pas godt på dine smykker"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Følg disse enkle trin for at bevare glansen i dine SIHO CPH smykker i mange år."
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "tip",
      "name": "Care Tip",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tip Title",
          "default": "Undgå kemikalier"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Tip Text",
          "default": "Tag dine smykker af når du bruger parfume, lotion eller hårspray."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SIHO Jewellery Care",
      "blocks": [
        { "type": "tip", "settings": { "title": "Undgå kemikalier", "text": "Tag dine smykker af før du påfører parfume, lotion eller andre kemikalier for at undgå misfarvning." } },
        { "type": "tip", "settings": { "title": "Tag smykkerne af ved træning", "text": "Sved kan påvirke belægningen på dine smykker. Tag dem af før sport eller fysisk aktivitet." } },
        { "type": "tip", "settings": { "title": "Opbevar dem tørt", "text": "Brug den medfølgende SIHO CPH smykkeæske til at opbevare dine smykker, når du ikke bruger dem." } },
        { "type": "tip", "settings": { "title": "Rengøring", "text": "Brug en blød klud til at tørre dine smykker over en gang imellem for at fjerne støv og fedt." } }
      ]
    }
  ]
}
{% endschema %}

{%- capture children -%}
  <div class="jewelry-care-grid">
    <div class="jewelry-care-header">
      <h2 class="h2">{{ section.settings.title | escape }}</h2>
      <p class="paragraph--large">{{ section.settings.subtitle | escape }}</p>
    </div>

    <div class="care-tips-grid">
      {%- for block in section.blocks -%}
        <div class="care-tip-item" {{ block.shopify_attributes }}>
          <h3 class="h6 care-tip-title">
            <span class="care-tip-icon svg-wrapper">
              {%- render 'jewelry-icons', icon: block.settings.icon_type -%}
            </span>
            {{ block.settings.title | escape }}
          </h3>
          <p class="care-tip-text paragraph--small">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endcapture -%}

{%- render 'section', section: section, children: children -%}

<style>
  /* ... (styles remain the same) ... */
</style>

{% schema %}
{
  "name": "SIHO Jewellery Care",
  "class": "section-wrapper",
  "settings": [
    /* ... (settings remain same) ... */
  ],
  "blocks": [
    {
      "type": "tip",
      "name": "Care Tip",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon Type",
          "options": [
            { "value": "care-brush", "label": "Cleaning Brush" },
            { "value": "care-box", "label": "Jewellery Box" },
            { "value": "care-water", "label": "Water/Cleaning" },
            { "value": "waterproof", "label": "Waterproof" },
            { "value": "silver", "label": "Silver Care" }
          ],
          "default": "care-brush"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tip Title",
          "default": "Undgå kemikalier"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Tip Text",
          "default": "Tag dine smykker af når du bruger parfume, lotion eller hårspray."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SIHO Jewellery Care",
      "blocks": [
        { "type": "tip", "settings": { "icon_type": "care-brush", "title": "Undgå kemikalier", "text": "Tag dine smykker af før du påfører parfume, lotion eller andre kemikalier for at undgå misfarvning." } },
        { "type": "tip", "settings": { "icon_type": "waterproof", "title": "Tag smykkerne af ved træning", "text": "Sved kan påvirke belægningen på dine smykker. Tag dem af før sport eller fysisk aktivitet." } },
        { "type": "tip", "settings": { "icon_type": "care-box", "title": "Opbevar dem tørt", "text": "Brug den medfølgende SIHO CPH smykkeæske til at opbevare dine smykker, når du ikke bruger dem." } },
        { "type": "tip", "settings": { "icon_type": "care-brush", "title": "Rengøring", "text": "Brug en blød klud til at tørre dine smykker over en gang imellem for at fjerne støv og fedt." } }
      ]
    }
  ]
}
{% endschema %}

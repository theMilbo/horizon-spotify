{%- capture children -%}
  <div class="brand-story">
    <div class="brand-story__text">
      <span class="brand-story__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      <h2 class="brand-story__title h3">{{ section.settings.title | escape }}</h2>
      <div class="brand-story__body rte">{{ section.settings.body }}</div>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="brand-story__cta">
          {{ section.settings.cta_text | escape }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="brand-story__visual">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 800 | image_tag:
          class: 'brand-story__image',
          loading: 'lazy',
          widths: '400,600,800',
          sizes: '(max-width: 749px) 90vw, 45vw'
        }}
      {%- else -%}
        <div class="brand-story__image-placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'brand-story__placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- if section.settings.badge_text != blank -%}
        <div class="brand-story__badge">
          <span class="brand-story__badge-text">{{ section.settings.badge_text | escape }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endcapture -%}

{%- render 'section', section: section, children: children -%}

<style>
  .brand-story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    width: 100%;
  }

  .brand-story__text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .brand-story__eyebrow {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.4;
    font-weight: 500;
    margin-block-end: 16px;
  }

  .brand-story__title {
    margin: 0 0 20px;
    letter-spacing: -0.025em;
    line-height: 1.15;
  }

  .brand-story__body {
    font-size: 0.95rem;
    line-height: 1.75;
    opacity: 0.65;
    max-width: 480px;
  }

  .brand-story__body p {
    margin: 0 0 12px;
  }

  .brand-story__body p:last-child {
    margin-bottom: 0;
  }

  .brand-story__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    color: var(--color-foreground);
    transition: opacity 0.3s ease, gap 0.3s ease;
  }

  .brand-story__cta:hover {
    opacity: 0.7;
    gap: 12px;
  }

  .brand-story__cta svg {
    transition: transform 0.3s ease;
  }

  .brand-story__cta:hover svg {
    transform: translateX(3px);
  }

  .brand-story__visual {
    position: relative;
  }

  .brand-story__image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: calc(var(--style-border-radius) + 8px);
  }

  .brand-story__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: calc(var(--style-border-radius) + 8px);
    background: rgba(var(--color-foreground-rgb), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .brand-story__placeholder-svg {
    width: 50%;
    height: auto;
    opacity: 0.12;
  }

  .brand-story__badge {
    position: absolute;
    bottom: 24px;
    right: 24px;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--color-foreground);
    color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    animation: brand-story-float 3s ease-in-out infinite;
  }

  @keyframes brand-story-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .brand-story__badge-text {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.3;
  }

  /* Tablet */
  @media screen and (max-width: 989px) {
    .brand-story {
      gap: 40px;
    }

    .brand-story__badge {
      width: 85px;
      height: 85px;
      bottom: 16px;
      right: 16px;
    }

    .brand-story__badge-text {
      font-size: 0.62rem;
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .brand-story {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .brand-story__visual {
      order: -1;
    }

    .brand-story__image {
      aspect-ratio: 16 / 10;
    }

    .brand-story__image-placeholder {
      aspect-ratio: 16 / 10;
    }

    .brand-story__body {
      max-width: none;
    }

    .brand-story__badge {
      width: 80px;
      height: 80px;
      bottom: 12px;
      right: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "SIHO Brand Story",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        { "value": "page-width", "label": "Sidebredde" },
        { "value": "full-width", "label": "Fuld bredde" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Tekst"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Undertekst over titel",
      "default": "Vores historie"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Overskrift",
      "default": "Dansk design med sjæl"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Brødtekst",
      "default": "<p>SIHO CPH er skabt af en passion for tidløst skandinavisk design. Hvert smykke er håndudvalgt med fokus på kvalitet, holdbarhed og den perfekte balance mellem elegance og hverdagsbrug.</p><p>Vi tror på, at smykker skal være mere end pynt — de skal fortælle din historie.</p>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA tekst",
      "default": "Læs mere om os"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Billede"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Billede"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge tekst (valgfrit)",
      "default": "Dansk design"
    },
    {
      "type": "header",
      "content": "Udseende"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Afstand"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top margin",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund margin",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "SIHO Brand Story"
    }
  ]
}
{% endschema %}

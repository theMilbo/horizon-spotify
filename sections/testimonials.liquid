          "id": "product",
          "label": "Produkt (valgfrit)",
          "default": "Sølv tennisarmbånd"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SIHO Anmeldelser",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Smykkerne er endnu smukkere i virkeligheden end på billederne. Utrolig kvalitet og hurtig levering!",
            "name": "Maria K.",
            "product": "Sølv tennisarmbånd"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Jeg har fået så mange komplimenter for min halskæde. Den perfekte gave til mig selv — elegant og tidløs.",
            "name": "Louise H.",
            "product": "Guld kædekæde"
          }

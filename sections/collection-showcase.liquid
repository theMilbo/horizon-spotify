      "default": "Udforsk vores håndudvalgte smykker"
    },
    {
      "type": "header",
      "content": "Udseende"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Afstand"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top margin",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund margin",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Kollektion kort",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Kollektion"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brugerdefineret billede (valgfrit)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Kollektion"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel (kun hvis ingen kollektion valgt)",
          "default": "Kollektion navn"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Beskrivelse",
          "default": "Udforsk vores smukke udvalg"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA tekst",
          "default": "Se kollektion"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SIHO Kollektioner",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "label": "Kollektion",
            "title": "Armbånd",
            "description": "Elegante armbånd i 925 sterling sølv og 18K guld",
            "cta_text": "Se armbånd"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "label": "Kollektion",
            "title": "Halskæder",
            "description": "Tidløse halskæder til enhver anledning",
            "cta_text": "Se halskæder"
          }
        }
      ]
    }
  ]
}
{% endschema %}

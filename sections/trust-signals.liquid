{%- capture children -%}
  <div class="trust-signals-grid">
    {%- for block in section.blocks -%}
      <div class="trust-signal-item" {{ block.shopify_attributes }}>
        <div class="trust-signal-icon svg-wrapper">
          {%- render 'jewelry-icons', icon: block.settings.icon_type -%}
        </div>
        <div class="trust-signal-content">
          <h3 class="trust-signal-title">{{ block.settings.title | escape }}</h3>
          <p class="trust-signal-text">{{ block.settings.text | escape }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
{%- endcapture -%}

{%- render 'section', section: section, children: children -%}

<style>
  .trust-signals-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--gap-md);
    width: 100%;
  }

  .trust-signal-item {
    flex: 1;
    min-width: 250px;
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    padding: var(--padding-md);
    background: rgba(var(--color-foreground-rgb), 0.03);
    border-radius: var(--style-border-radius);
    transition: transform var(--hover-transition-duration) var(--hover-transition-timing);
  }

  .trust-signal-item:hover {
    transform: translateY(-2px);
    background: rgba(var(--color-foreground-rgb), 0.05);
  }

  .trust-signal-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    color: var(--color-foreground);
  }

  .trust-signal-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .trust-signal-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .trust-signal-text {
    margin: 0;
    font-size: 0.85rem;
    opacity: 0.7;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .trust-signal-item {
      min-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "SIHO Trust Signals",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "signal",
      "name": "Trust Signal",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon Type",
          "options": [
            { "value": "silver", "label": "925 Silver" },
            { "value": "gold", "label": "18K Gold" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "sustainable", "label": "Sustainable" },
            { "value": "waterproof", "label": "Waterproof" }
          ],
          "default": "silver"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "High Quality"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Crafted with precision."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SIHO Trust Signals",
      "blocks": [
        { "type": "signal", "settings": { "icon_type": "silver", "title": "925 Sterling Sølv", "text": "Ægte sølv i højeste kvalitet." } },
        { "type": "signal", "settings": { "icon_type": "gold", "title": "18K Forgyldning", "text": "Holdbar og luksuriøs finish." } },
        { "type": "signal", "settings": { "icon_type": "waterproof", "title": "Vandfaste smykker", "text": "Brug dem hele dagen, hver dag." } }
      ]
    }
  ]
}
{% endschema %}

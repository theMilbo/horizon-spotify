{%- liquid
  assign section_id = section.id | prepend: 'section-'
-%}

<style>
  #{{ section_id }} {
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .trust-signals-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 30px;
  }

  .trust-signal-item {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .trust-signal-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.icon_color }};
  }

  .trust-signal-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  .trust-signal-text {
    font-size: 0.9rem;
    margin: 0;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  @media screen and (max-width: 768px) {
    .trust-signals-container {
      flex-direction: column;
      align-items: center;
    }
    .trust-signal-item {
      max-width: 300px;
    }
  }
</style>

<div id="{{ section_id }}">
  <div class="trust-signals-container">
    {%- for block in section.blocks -%}
      <div class="trust-signal-item">
        <div class="trust-signal-icon">
          {%- render 'jewelry-icons', icon: block.settings.icon_type -%}
        </div>
        <h3 class="trust-signal-title">{{ block.settings.title | escape }}</h3>
        <p class="trust-signal-text">{{ block.settings.text | escape }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "SIHO Trust Signals",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "signal",
      "name": "Trust Signal",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon Type",
          "options": [
            { "value": "silver", "label": "925 Silver" },
            { "value": "gold", "label": "18K Gold" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "sustainable", "label": "Sustainable" },
            { "value": "waterproof", "label": "Waterproof" }
          ],
          "default": "silver"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "High Quality"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Crafted with precision."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SIHO Trust Signals",
      "blocks": [
        { "type": "signal", "settings": { "icon_type": "silver", "title": "925 Sterling Sølv", "text": "Ægte sølv i højeste kvalitet." } },
        { "type": "signal", "settings": { "icon_type": "gold", "title": "18K Forgyldning", "text": "Holdbar og luksuriøs finish." } },
        { "type": "signal", "settings": { "icon_type": "waterproof", "title": "Vandfaste smykker", "text": "Brug dem hele dagen, hver dag." } }
      ]
    }
  ]
}
{% endschema %}

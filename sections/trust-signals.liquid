{%- capture children -%}
  <div class="trust-signals">
    {%- for block in section.blocks -%}
      <div class="trust-signal" {{ block.shopify_attributes }}>
        <div class="trust-signal__icon-wrap">
          <div class="trust-signal__icon svg-wrapper">
            {%- render 'jewelry-icons', icon: block.settings.icon_type -%}
          </div>
        </div>
        <div class="trust-signal__content">
          <h3 class="trust-signal__title">{{ block.settings.title | escape }}</h3>
          <p class="trust-signal__text">{{ block.settings.text | escape }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
{%- endcapture -%}

{%- render 'section', section: section, children: children -%}

<style>
  .trust-signals {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    width: 100%;
    background: rgba(var(--color-foreground-rgb), 0.06);
    border-radius: calc(var(--style-border-radius) + 4px);
    overflow: hidden;
  }

  .trust-signal {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 28px 32px;
    background: var(--color-background);
    transition: background 0.3s ease;
  }

  .trust-signal:hover {
    background: rgba(var(--color-foreground-rgb), 0.02);
  }

  .trust-signal__icon-wrap {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-foreground-rgb), 0.05);
    border-radius: 50%;
    transition: transform 0.35s ease, background 0.35s ease, box-shadow 0.35s ease;
  }

  .trust-signal:hover .trust-signal__icon-wrap {
    transform: scale(1.08);
    background: rgba(var(--color-foreground-rgb), 0.08);
    box-shadow: 0 4px 20px rgba(var(--color-foreground-rgb), 0.06);
  }

  .trust-signal__icon {
    width: 26px;
    height: 26px;
    color: var(--color-foreground);
    opacity: 0.75;
  }

  .trust-signal__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-signal__title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .trust-signal__text {
    margin: 0;
    font-size: 0.82rem;
    opacity: 0.55;
    line-height: 1.5;
    letter-spacing: 0.01em;
  }

  /* Tablet: 2 columns */
  @media screen and (max-width: 989px) and (min-width: 750px) {
    .trust-signals {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile: elegant vertical stack */
  @media screen and (max-width: 749px) {
    .trust-signals {
      grid-template-columns: 1fr;
      border-radius: var(--style-border-radius);
    }

    .trust-signal {
      padding: 20px 24px;
      gap: 16px;
    }

    .trust-signal__icon-wrap {
      width: 44px;
      height: 44px;
    }

    .trust-signal__icon {
      width: 20px;
      height: 20px;
    }

    .trust-signal__title {
      font-size: 0.9rem;
    }

    .trust-signal__text {
      font-size: 0.78rem;
    }
  }
</style>

{% schema %}
{
  "name": "SIHO Tillidssignaler",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        { "value": "page-width", "label": "Sidebredde" },
        { "value": "full-width", "label": "Fuld bredde" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Udseende"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Afstand"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top margin",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund margin",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "signal",
      "name": "Tillidssignal",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Ikon type",
          "options": [
            { "value": "silver", "label": "925 Sølv" },
            { "value": "gold", "label": "18K Guld" },
            { "value": "diamond", "label": "Diamant" },
            { "value": "sustainable", "label": "Bæredygtig" },
            { "value": "waterproof", "label": "Vandfast" },
            { "value": "shipping", "label": "Levering" },
            { "value": "gift", "label": "Gave" },
            { "value": "guarantee", "label": "Garanti" }
          ],
          "default": "silver"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Høj Kvalitet"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Beskrivelse",
          "default": "Udført med præcision."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SIHO Tillidssignaler",
      "blocks": [
        { "type": "signal", "settings": { "icon_type": "silver", "title": "925 Sterling Sølv", "text": "Ægte sølv i højeste kvalitet" } },
        { "type": "signal", "settings": { "icon_type": "gold", "title": "18K Forgyldning", "text": "Holdbar og luksuriøs finish" } },
        { "type": "signal", "settings": { "icon_type": "waterproof", "title": "Vandfaste smykker", "text": "Brug dem hele dagen, hver dag" } }
      ]
    }
  ]
}
{% endschema %}

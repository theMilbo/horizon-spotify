    "faq_section": {
      "type": "faq-jewelry",
      "blocks": {
        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "Hvilke typer halskæder tilbyder I?",
            "answer": "<p>Vi har et kurateret udvalg af halskæder i 925 sterling sølv og 18K guldbelagt sølv — fra fine kædekæder og vedhæng til chunky statement-halskæder og lagdelte styles.</p>"
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "Hvilken længde halskæde skal jeg vælge?",
            "answer": "<p>Vores halskæder fås typisk i 40-45 cm (choker/princess) og 50-60 cm (matinée). Vi anbefaler at måle en halskæde du allerede ejer for at finde din foretrukne længde.</p>"
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "Kan jeg bade med mine halskæder på?",
            "answer": "<p>Ja, vores halskæder er vandfaste og designet til daglig brug. Vi anbefaler dog at undgå langvarig kontakt med klorvand og parfume for at bevare den smukke overflade.</p>"
          }
        }
      },
      "block_order": ["faq_1", "faq_2", "faq_3"],
      "settings": {
        "section_width": "page-width",
        "title": "Ofte stillede spørgsmål om halskæder",
        "subtitle": "",
        "color_scheme": "",
        "padding-block-start": 48,
        "padding-block-end": 60
      }
    }

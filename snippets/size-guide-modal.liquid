{% comment %}
  SIHO CPH Size Guide Modal - Horizon Native Refactor
{% endcomment %}

<dialog
  id="SizeGuideModal"
  class="size-guide-modal dialog-modal color-{{ settings.popover_color_scheme }}"
  scroll-lock
>
  <div class="size-guide-modal__inner">
    <button
      class="button button-unstyled size-guide-modal__close"
      onclick="document.getElementById('SizeGuideModal').close()"
      aria-label="{{ 'accessibility.close_dialog' | t }}"
    >
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>

    <div class="size-guide-modal__content">
      <h2 class="size-guide-modal__title h3">Størrelsesguide</h2>
      
      <div class="size-guide-tabs">
        <button class="size-guide-tab active" data-tab="rings">Ringe</button>
        <button class="size-guide-tab" data-tab="necklaces">Halskæder</button>
      </div>

      <div id="rings" class="size-guide-pane active">
        <div class="table-wrapper">
          <table class="size-table">
            <thead>
              <tr>
                <th>EU Str.</th>
                <th>Diam. (mm)</th>
                <th>US Str.</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>50</td><td>15.9</td><td>5</td></tr>
              <tr><td>52</td><td>16.5</td><td>6</td></tr>
              <tr><td>54</td><td>17.2</td><td>7</td></tr>
              <tr><td>56</td><td>17.8</td><td>8</td></tr>
              <tr><td>58</td><td>18.5</td><td>9</td></tr>
            </tbody>
          </table>
        </div>
        <div class="size-instructions paragraph--small">
          <h4 class="h6">Mål din ringstørrelse:</h4>
          <p>Brug en snor rundt om din finger, marker overlap, og mål længden i mm. Dette tal er din EU størrelse.</p>
        </div>
      </div>

      <div id="necklaces" class="size-guide-pane">
        <div class="table-wrapper">
          <table class="size-table">
            <thead>
              <tr>
                <th>Længde (cm)</th>
                <th>Type</th>
                <th>Placering</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>35-40</td><td>Choker</td><td>Højt på halsen</td></tr>
              <tr><td>42-45</td><td>Prinsesse</td><td>Kravebenet</td></tr>
              <tr><td>50-55</td><td>Matine</td><td>Midt på brystet</td></tr>
            </tbody>
          </table>
        </div>
        <div class="size-instructions paragraph--small">
          <h4 class="h6">Den perfekte længde:</h4>
          <p>De fleste SIHO halskæder har et 5cm forlængerstykke for optimal tilpasning.</p>
        </div>
      </div>
    </div>
  </div>
</dialog>

<script>
  // Simple Tab Logic
  document.querySelectorAll('.size-guide-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      document.querySelectorAll('.size-guide-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.size-guide-pane').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(target).classList.add('active');
    });
  });

  // Global helper for the button
  window.openSizeGuide = () => {
    const modal = document.getElementById('SizeGuideModal');
    if (modal) modal.showModal();
  };
</script>

{% stylesheet %}
  .size-guide-modal {
    padding: 0;
    border: var(--style-border-popover);
    border-radius: var(--style-border-radius-popover);
    width: 90vw;
    max-width: 600px;
    max-height: 80vh;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    background: var(--color-background);
  }

  .size-guide-modal[open] {
    animation: modalSlideInTop var(--submenu-animation-speed) var(--submenu-animation-easing) forwards;
  }

  .size-guide-modal::backdrop {
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(4px);
  }

  .size-guide-modal__inner {
    position: relative;
    padding: var(--padding-2xl);
    height: 100%;
    overflow-y: auto;
  }

  .size-guide-modal__close {
    position: absolute;
    top: var(--margin-xs);
    right: var(--margin-xs);
    width: 32px;
    height: 32px;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .size-guide-modal__close:hover { opacity: 1; }

  .size-guide-modal__title {
    text-align: center;
    margin-bottom: var(--margin-lg);
  }

  .size-guide-tabs {
    display: flex;
    justify-content: center;
    gap: var(--gap-md);
    margin-bottom: var(--margin-lg);
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.1);
  }

  .size-guide-tab {
    background: none;
    border: none;
    padding: 10px 15px;
    cursor: pointer;
    font-size: 0.8rem;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0.4;
    transition: opacity 0.2s;
  }

  .size-guide-tab.active {
    opacity: 1;
    border-bottom: 2px solid var(--color-foreground);
  }

  .size-guide-pane { display: none; }
  .size-guide-pane.active { display: block; }

  .size-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--margin-md);
  }

  .size-table th, .size-table td {
    padding: 12px;
    text-align: center;
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.05);
  }

  .size-table th {
    font-size: 0.7rem;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .size-instructions {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px dotted rgba(var(--color-foreground-rgb), 0.2);
  }

  .size-instructions h4 { margin-bottom: 8px; }
{% endstylesheet %}

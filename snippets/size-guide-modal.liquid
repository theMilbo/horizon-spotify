{% comment %}
  SIHO CPH Size Guide Modal
{% endcomment %}

<style>
  .size-guide-modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.5);
    backdrop-filter: blur(5px);
  }

  .size-guide-content {
    background-color: #fff;
    margin: 5% auto;
    padding: 40px;
    border-radius: 4px;
    width: 90%;
    max-width: 800px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .size-guide-close {
    position: absolute;
    right: 20px;
    top: 15px;
    font-size: 30px;
    cursor: pointer;
    color: #999;
  }

  .size-guide-title {
    text-align: center;
    margin-bottom: 30px;
    font-family: serif;
    font-size: 2rem;
  }

  .size-guide-tabs {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 30px;
    border-bottom: 1px solid #eee;
  }

  .size-guide-tab {
    padding: 10px 20px;
    cursor: pointer;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
    opacity: 0.5;
  }

  .size-guide-tab.active {
    opacity: 1;
    border-bottom: 2px solid #000;
  }

  .size-guide-pane {
    display: none;
  }

  .size-guide-pane.active {
    display: block;
  }

  .size-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
  }

  .size-table th, .size-table td {
    padding: 12px;
    text-align: center;
    border-bottom: 1px solid #f0f0f0;
  }

  .size-table th {
    background-color: #f9f9f9;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.8rem;
  }

  .size-instructions {
    margin-top: 40px;
  }

  .size-instructions h4 {
    margin-bottom: 15px;
    font-weight: 600;
  }

  .size-instructions p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #444;
  }
</style>

<div id="SizeGuideModal" class="size-guide-modal">
  <div class="size-guide-content">
    <span class="size-guide-close" onclick="closeSizeGuide()">&times;</span>
    <h2 class="size-guide-title">Størrelsesguide</h2>
    
    <div class="size-guide-tabs">
      <div class="size-guide-tab active" data-tab="rings">Ringe</div>
      <div class="size-guide-tab" data-tab="necklaces">Halskæder</div>
    </div>

    <div id="rings" class="size-guide-pane active">
      <table class="size-table">
        <thead>
          <tr>
            <th>EU Størrelse</th>
            <th>Indvendig Diam. (mm)</th>
            <th>US Størrelse</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>50</td><td>15.9</td><td>5</td></tr>
          <tr><td>52</td><td>16.5</td><td>6</td></tr>
          <tr><td>54</td><td>17.2</td><td>7</td></tr>
          <tr><td>56</td><td>17.8</td><td>8</td></tr>
          <tr><td>58</td><td>18.5</td><td>9</td></tr>
        </tbody>
      </table>
      <div class="size-instructions">
        <h4>Sådan måler du din ringstørrelse:</h4>
        <p>1. Brug en snor eller et stykke papir rundt om din finger.<br>
        2. Marker det punkt, hvor de to ender mødes.<br>
        3. Mål længden i millimeter – dette er din omkreds (EU Størrelse).</p>
      </div>
    </div>

    <div id="necklaces" class="size-guide-pane">
      <table class="size-table">
        <thead>
          <tr>
            <th>Længde (cm)</th>
            <th>Type</th>
            <th>Placering</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>35-40</td><td>Choker</td><td>Højt på halsen</td></tr>
          <tr><td>42-45</td><td>Prinsesse</td><td>Lige under kravebenet</td></tr>
          <tr><td>50-55</td><td>Matine</td><td>Midt på brystet</td></tr>
        </tbody>
      </table>
      <div class="size-instructions">
        <h4>Find den perfekte længde:</h4>
        <p>De fleste af vores halskæder kommer med et forlængerstykke på 5 cm, så du kan justere længden præcis som du ønsker det.</p>
      </div>
    </div>
  </div>
</div>

<script>
  function openSizeGuide() {
    document.getElementById('SizeGuideModal').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeSizeGuide() {
    document.getElementById('SizeGuideModal').style.display = 'none';
    document.body.style.overflow = 'auto';
  }

  // Simple Tab Logic
  document.querySelectorAll('.size-guide-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      
      document.querySelectorAll('.size-guide-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.size-guide-pane').forEach(p => p.classList.remove('active'));
      
      tab.classList.add('active');
      document.getElementById(target).classList.add('active');
    });
  });

  // Close on backdrop click
  window.onclick = function(event) {
    const modal = document.getElementById('SizeGuideModal');
    if (event.target == modal) {
      closeSizeGuide();
    }
  }
</script>

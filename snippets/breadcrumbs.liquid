{% comment %}
  SIHO CPH Visual Breadcrumbs - Elegant Navigation
  Use: {% render 'breadcrumbs' %}
  Renders on: product, collection, article, page, blog
{% endcomment %}

{% unless request.page_type == 'index' or request.page_type == 'cart' or request.page_type == 'password' or request.page_type == 'search' %}
  <nav class="breadcrumbs" aria-label="Brødkrumme">
    <ol class="breadcrumbs__list" itemscope itemtype="https://schema.org/BreadcrumbList">
      <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a href="/" class="breadcrumbs__link" itemprop="item">
          <span itemprop="name">Forside</span>
        </a>
        <meta itemprop="position" content="1">
      </li>

      {% if request.page_type == 'collection' %}
        <li class="breadcrumbs__item breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" aria-current="page">{{ collection.title }}</span>
          <meta itemprop="item" content="{{ shop.url }}{{ collection.url }}">
          <meta itemprop="position" content="2">
        </li>

      {% elsif request.page_type == 'product' %}
        {% if collection %}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="{{ collection.url }}" class="breadcrumbs__link" itemprop="item">
              <span itemprop="name">{{ collection.title }}</span>
            </a>
            <meta itemprop="position" content="2">
          </li>
        {% else %}
          <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="/collections/all" class="breadcrumbs__link" itemprop="item">
              <span itemprop="name">Smykker</span>
            </a>
            <meta itemprop="position" content="2">
          </li>
        {% endif %}
        <li class="breadcrumbs__item breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" aria-current="page">{{ product.title }}</span>
          <meta itemprop="item" content="{{ shop.url }}{{ product.url }}">
          <meta itemprop="position" content="3">
        </li>

      {% elsif request.page_type == 'article' %}
        <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="{{ blog.url }}" class="breadcrumbs__link" itemprop="item">
            <span itemprop="name">{{ blog.title }}</span>
          </a>
          <meta itemprop="position" content="2">
        </li>
        <li class="breadcrumbs__item breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" aria-current="page">{{ article.title }}</span>
          <meta itemprop="item" content="{{ shop.url }}{{ article.url }}">
          <meta itemprop="position" content="3">
        </li>

      {% elsif request.page_type == 'blog' %}
        <li class="breadcrumbs__item breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" aria-current="page">{{ blog.title }}</span>
          <meta itemprop="item" content="{{ shop.url }}{{ blog.url }}">
          <meta itemprop="position" content="2">
        </li>

      {% elsif request.page_type == 'page' %}
        <li class="breadcrumbs__item breadcrumbs__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" aria-current="page">{{ page.title }}</span>
          <meta itemprop="item" content="{{ shop.url }}{{ page.url }}">
          <meta itemprop="position" content="2">
        </li>
      {% endif %}
    </ol>
  </nav>

  <style>
    .breadcrumbs {
      padding: 16px 0 8px;
      font-size: 0.8rem;
      letter-spacing: 0.03em;
    }

    .breadcrumbs__list {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .breadcrumbs__item {
      display: flex;
      align-items: center;
      color: var(--color-foreground);
      opacity: 0.5;
    }

    .breadcrumbs__item:not(:last-child)::after {
      content: '/';
      margin-inline: 8px;
      opacity: 0.4;
      font-size: 0.75em;
    }

    .breadcrumbs__item--current {
      opacity: 0.8;
      font-weight: 500;
    }

    .breadcrumbs__link {
      color: inherit;
      text-decoration: none;
      transition: opacity 0.2s ease;
    }

    .breadcrumbs__link:hover {
      opacity: 0.7;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    @media screen and (max-width: 749px) {
      .breadcrumbs {
        font-size: 0.75rem;
        padding: 12px 0 4px;
      }
    }
  </style>
{% endunless %}

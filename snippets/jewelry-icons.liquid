{% comment %}
  SIHO CPH Jewellery Icons - Elegant & Refined
  Use: {% render 'jewelry-icons', icon: 'silver' %}
{% endcomment %}

{% case icon %}
  {% when 'silver' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.25"/>
      <path d="M8.5 12.5C8.5 12.5 10 15 12 15C14 15 15.5 12.5 15.5 12.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <text x="12" y="10.5" text-anchor="middle" fill="currentColor" font-size="5" font-weight="600" font-family="system-ui">925</text>
    </svg>
  {% when 'gold' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="4" y="8" width="16" height="8" rx="2" stroke="currentColor" stroke-width="1.25"/>
      <path d="M8 8V6a4 4 0 0 1 8 0v2" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <circle cx="12" cy="12" r="1.5" fill="currentColor" opacity="0.6"/>
    </svg>
  {% when 'diamond' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2L4 9L12 22L20 9L12 2Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      <path d="M4 9H20" stroke="currentColor" stroke-width="1.25"/>
      <path d="M9 2L7 9L12 22L17 9L15 2" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
    </svg>
  {% when 'sustainable' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <path d="M12 2C17.5 2 22 6.5 22 12S17.5 22 12 22" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-dasharray="3 3"/>
      <path d="M12 8V16M8 12H16" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
    </svg>
  {% when 'waterproof' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3C12 3 6 11 6 15.5C6 18.8 8.7 21.5 12 21.5C15.3 21.5 18 18.8 18 15.5C18 11 12 3 12 3Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      <path d="M9.5 16C9.5 17.4 10.6 18.5 12 18.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" opacity="0.5"/>
    </svg>
  {% when 'care-brush' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 4L14 10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <path d="M18.5 2.5L21.5 5.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <path d="M14 10L11 13L7.5 16.5C6.1 17.9 3.9 17.9 2.5 16.5V16.5C1.1 15.1 1.1 12.9 2.5 11.5L6 8L10 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 10L14 14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" opacity="0.4"/>
    </svg>
  {% when 'care-box' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="3" y="9" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.25"/>
      <path d="M3 9L5 5H19L21 9" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      <path d="M10 13H14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <line x1="12" y1="9" x2="12" y2="5" stroke="currentColor" stroke-width="1.25" opacity="0.4"/>
    </svg>
  {% when 'care-water' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3C12 3 5 12 5 16.5C5 20.1 8.1 22 12 22C15.9 22 19 20.1 19 16.5C19 12 12 3 12 3Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      <path d="M8 17C8.5 18.5 10 19.5 12 19.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" opacity="0.4"/>
      <path d="M9 14.5H15" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" opacity="0.3"/>
    </svg>
  {% when 'shipping' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3 7H16V17H3V7Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      <path d="M16 10H20L22 13V17H16V10Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      <circle cx="7.5" cy="17" r="2" stroke="currentColor" stroke-width="1.25"/>
      <circle cx="18.5" cy="17" r="2" stroke="currentColor" stroke-width="1.25"/>
    </svg>
  {% when 'gift' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="3" y="8" width="18" height="13" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
      <path d="M12 8V21" stroke="currentColor" stroke-width="1.25"/>
      <path d="M3 12H21" stroke="currentColor" stroke-width="1.25"/>
      <path d="M7.5 8C7.5 8 7.5 4 10 4C12 4 12 6 12 8" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <path d="M16.5 8C16.5 8 16.5 4 14 4C12 4 12 6 12 8" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
    </svg>
  {% when 'guarantee' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2L4 6V12C4 17 7.5 21.2 12 22C16.5 21.2 20 17 20 12V6L12 2Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {% when 'heart' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 21C12 21 3 14.5 3 8.5C3 5.4 5.4 3 8.5 3C10.2 3 11.7 3.8 12 5C12.3 3.8 13.8 3 15.5 3C18.6 3 21 5.4 21 8.5C21 14.5 12 21 12 21Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
    </svg>
  {% when 'ring' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="12" cy="14" rx="8" ry="6" stroke="currentColor" stroke-width="1.25"/>
      <path d="M10 4L12 8L14 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="12" cy="4" r="1" fill="currentColor" opacity="0.6"/>
    </svg>
  {% when 'necklace' %}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M6 3C6 3 4 8 4 12C4 16.4 7.6 20 12 20C16.4 20 20 16.4 20 12C20 8 18 3 18 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <path d="M10 18L12 22L14 18" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
{% endcase %}
